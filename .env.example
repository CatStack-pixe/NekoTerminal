# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service_role 密钥（仅服务端使用，绕过 RLS）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (生产环境必填，用于 Magic Link 回调)
NEXT_PUBLIC_SITE_URL=https://nekoterminal.netlify.app

# AI API
AI_API_URL=https://your-ai-api.example.com
AI_API_KEY=your-api-key

# Cloudflare R2 / S3 Compatible Storage（可选）
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=catstack-uploads
R2_PUBLIC_URL=https://your-bucket.r2.cloudflarestorage.com
